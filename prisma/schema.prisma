generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  DIRECTIVO
  ADMINISTRATIVO
  DOCENTE
  ESTUDIANTE
  ACUDIENTE
  PSICORIENTADOR
  COORDINADOR
}

enum EstadoUpa {
  BORRADOR
  ENVIADA
  EN_REVISION
  REQUIERE_AJUSTES
  APROBADA
}

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  TARDE
  CITA
  HOSPITALIZADO
  EN_CUARTO
}

model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String
  correo        String     @unique
  password      String
  rol           RolUsuario
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  docente                Docente?
  administrativo         Administrativo?
  estudiante             Estudiante?
  acudiente              Acudiente?
  upaRetroalimentaciones UpaRetroalimentacion[]
}

model Docente {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @unique
  documento String?  @unique
  telefono  String?
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  gruposDirigidos        Grupo[]
  asistencias            Asistencia[]
  observaciones          Observacion[]
  asignacionesAcademicas AsignacionAcademica[]
  upas                   Upa[]
}

model Administrativo {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @unique
  cargo     String?
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model Estudiante {
  id        Int      @id @default(autoincrement())
  usuarioId Int?     @unique
  nombre    String
  documento String?  @unique
  grupoId   Int?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  grupo   Grupo?   @relation(fields: [grupoId], references: [id])

  acudientes    EstudianteAcudiente[]
  asistencias   Asistencia[]
  observaciones Observacion[]
}

model Acudiente {
  id        Int      @id @default(autoincrement())
  usuarioId Int?     @unique
  nombre    String
  documento String?  @unique
  telefono  String?
  correo    String?
  creadoEn  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  estudiantes EstudianteAcudiente[]
}

model EstudianteAcudiente {
  id           Int     @id @default(autoincrement())
  estudianteId Int
  acudienteId  Int
  parentesco   String?

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  acudiente  Acudiente  @relation(fields: [acudienteId], references: [id])

  @@unique([estudianteId, acudienteId])
}

model Grupo {
  id                Int      @id @default(autoincrement())
  nombre            String
  grado             String?
  directorDocenteId Int?
  activo            Boolean  @default(true)
  creadoEn          DateTime @default(now())

  directorDocente Docente? @relation(fields: [directorDocenteId], references: [id])

  estudiantes            Estudiante[]
  asistencias            Asistencia[]
  observaciones          Observacion[]
  asignacionesAcademicas AsignacionAcademica[]
  upas                   Upa[]
}

model Asistencia {
  id                    Int              @id @default(autoincrement())
  estudianteId          Int
  docenteId             Int
  grupoId               Int
  asignacionAcademicaId Int?
  fecha                 DateTime
  estado                EstadoAsistencia
  emocion               String?
  observacion           String?
  creadoEn              DateTime         @default(now())

  estudiante          Estudiante           @relation(fields: [estudianteId], references: [id])
  docente             Docente              @relation(fields: [docenteId], references: [id])
  grupo               Grupo                @relation(fields: [grupoId], references: [id])
  asignacionAcademica AsignacionAcademica? @relation(fields: [asignacionAcademicaId], references: [id])

  @@unique([estudianteId, asignacionAcademicaId, fecha])
}

model Observacion {
  id              Int      @id @default(autoincrement())
  estudianteId    Int?
  docenteId       Int
  grupoId         Int
  fecha           DateTime @default(now())
  tipo            String
  descripcion     String
  enviarAcudiente Boolean  @default(false)
  creadoEn        DateTime @default(now())

  estudiante Estudiante? @relation(fields: [estudianteId], references: [id])
  docente    Docente     @relation(fields: [docenteId], references: [id])
  grupo      Grupo       @relation(fields: [grupoId], references: [id])
}

model Area {
  id                     Int                   @id @default(autoincrement())
  nombre                 String                @unique
  descripcion            String?
  activo                 Boolean               @default(true)
  creadoEn               DateTime              @default(now())
  actualizadoEn          DateTime              @updatedAt
  asignacionesAcademicas AsignacionAcademica[]
  upas                   Upa[]
}

model AsignacionAcademica {
  id            Int      @id @default(autoincrement())
  docenteId     Int
  grupoId       Int
  areaId        Int
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  docente Docente @relation(fields: [docenteId], references: [id])
  grupo   Grupo   @relation(fields: [grupoId], references: [id])
  area    Area    @relation(fields: [areaId], references: [id])

  asistencias Asistencia[]
  upas        Upa[]

  @@unique([docenteId, grupoId, areaId])
}

model DashboardNoticia {
  id                      Int      @id @default(autoincrement())
  titulo                  String
  descripcion             String
  color                   String?  @default("azul")
  orden                   Int      @default(0)
  activo                  Boolean  @default(true)
  creadoPorUsuarioId      Int?
  actualizadoPorUsuarioId Int?
  creadoEn                DateTime @default(now())
  actualizadoEn           DateTime @updatedAt
}

model DashboardEvento {
  id                      Int      @id @default(autoincrement())
  titulo                  String
  fecha                   DateTime
  color                   String?  @default("azul")
  orden                   Int      @default(0)
  activo                  Boolean  @default(true)
  creadoPorUsuarioId      Int?
  actualizadoPorUsuarioId Int?
  creadoEn                DateTime @default(now())
  actualizadoEn           DateTime @updatedAt
}

model DashboardGaleria {
  id                      Int      @id @default(autoincrement())
  titulo                  String
  descripcion             String?
  imagenUrl               String?
  orden                   Int      @default(0)
  activo                  Boolean  @default(true)
  creadoPorUsuarioId      Int?
  actualizadoPorUsuarioId Int?
  creadoEn                DateTime @default(now())
  actualizadoEn           DateTime @updatedAt
}

model Upa {
  id                    Int       @id @default(autoincrement())
  nombre                String
  mision                String
  salidaPedagogicaTexto String?
  semanasNumero         Int
  estado                EstadoUpa @default(BORRADOR)

  docenteId             Int
  grupoId               Int?
  areaId                Int?
  asignacionAcademicaId Int?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  docente             Docente              @relation(fields: [docenteId], references: [id])
  grupo               Grupo?               @relation(fields: [grupoId], references: [id])
  area                Area?                @relation(fields: [areaId], references: [id])
  asignacionAcademica AsignacionAcademica? @relation(fields: [asignacionAcademicaId], references: [id])

  semanas             UpaSemana[]
  retroalimentaciones UpaRetroalimentacion[]
}

model UpaSemana {
  id           Int    @id @default(autoincrement())
  upaId        Int
  numeroSemana Int
  detalle      String

  upa Upa @relation(fields: [upaId], references: [id])

  @@unique([upaId, numeroSemana])
}

model UpaRetroalimentacion {
  id                   Int        @id @default(autoincrement())
  upaId                Int
  coordinadorUsuarioId Int
  comentario           String
  estadoSugerido       EstadoUpa?
  creadoEn             DateTime   @default(now())

  upa                Upa     @relation(fields: [upaId], references: [id])
  coordinadorUsuario Usuario @relation(fields: [coordinadorUsuarioId], references: [id])
}
