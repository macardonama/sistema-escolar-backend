generator client {
  provider = "prisma-client-js"
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "./ERD.svg"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  DIRECTIVO
  ADMINISTRATIVO
  DOCENTE
  ESTUDIANTE
  ACUDIENTE
  PSICORIENTADOR
}

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  TARDE
  CITA
  HOSPITALIZADO
  EN_CUARTO
}

model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String
  correo        String     @unique
  password      String
  rol           RolUsuario
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now())
  actualizadoEn DateTime   @updatedAt

  docente        Docente?
  administrativo Administrativo?
  estudiante     Estudiante?
  acudiente      Acudiente?
}

model Docente {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @unique
  documento String?  @unique
  telefono  String?
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  gruposDirigidos        Grupo[]
  asistencias            Asistencia[]
  observaciones          Observacion[]
  asignacionesAcademicas AsignacionAcademica[]
}

model Administrativo {
  id        Int      @id @default(autoincrement())
  usuarioId Int      @unique
  cargo     String?
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id])
}

model Estudiante {
  id        Int      @id @default(autoincrement())
  usuarioId Int?     @unique
  nombre    String
  documento String?  @unique
  grupoId   Int?
  activo    Boolean  @default(true)
  creadoEn  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])
  grupo   Grupo?   @relation(fields: [grupoId], references: [id])

  acudientes    EstudianteAcudiente[]
  asistencias   Asistencia[]
  observaciones Observacion[]
}

model Acudiente {
  id        Int      @id @default(autoincrement())
  usuarioId Int?     @unique
  nombre    String
  telefono  String?
  correo    String?
  creadoEn  DateTime @default(now())

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  estudiantes EstudianteAcudiente[]
}

model EstudianteAcudiente {
  id           Int     @id @default(autoincrement())
  estudianteId Int
  acudienteId  Int
  parentesco   String?

  estudiante Estudiante @relation(fields: [estudianteId], references: [id])
  acudiente  Acudiente  @relation(fields: [acudienteId], references: [id])

  @@unique([estudianteId, acudienteId])
}

model Grupo {
  id                Int      @id @default(autoincrement())
  nombre            String
  grado             String?
  directorDocenteId Int?
  activo            Boolean  @default(true)
  creadoEn          DateTime @default(now())

  directorDocente Docente? @relation(fields: [directorDocenteId], references: [id])

  estudiantes            Estudiante[]
  asistencias            Asistencia[]
  observaciones          Observacion[]
  asignacionesAcademicas AsignacionAcademica[]
}

model Asistencia {
  id                    Int              @id @default(autoincrement())
  estudianteId          Int
  docenteId             Int
  grupoId               Int
  asignacionAcademicaId Int?
  fecha                 DateTime
  estado                EstadoAsistencia
  emocion               String?
  observacion           String?
  creadoEn              DateTime         @default(now())

  estudiante          Estudiante           @relation(fields: [estudianteId], references: [id])
  docente             Docente              @relation(fields: [docenteId], references: [id])
  grupo               Grupo                @relation(fields: [grupoId], references: [id])
  asignacionAcademica AsignacionAcademica? @relation(fields: [asignacionAcademicaId], references: [id])

  @@unique([estudianteId, asignacionAcademicaId, fecha])
}

model Observacion {
  id              Int      @id @default(autoincrement())
  estudianteId    Int?
  docenteId       Int
  grupoId         Int
  fecha           DateTime @default(now())
  tipo            String
  descripcion     String
  enviarAcudiente Boolean  @default(false)
  creadoEn        DateTime @default(now())

  estudiante Estudiante? @relation(fields: [estudianteId], references: [id])
  docente    Docente     @relation(fields: [docenteId], references: [id])
  grupo      Grupo       @relation(fields: [grupoId], references: [id])
}

model Area {
  id                     Int                   @id @default(autoincrement())
  nombre                 String                @unique
  descripcion            String?
  activo                 Boolean               @default(true)
  creadoEn               DateTime              @default(now())
  actualizadoEn          DateTime              @updatedAt
  asignacionesAcademicas AsignacionAcademica[]
}

model AsignacionAcademica {
  id            Int      @id @default(autoincrement())
  docenteId     Int
  grupoId       Int
  areaId        Int
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  docente Docente @relation(fields: [docenteId], references: [id])
  grupo   Grupo   @relation(fields: [grupoId], references: [id])
  area    Area    @relation(fields: [areaId], references: [id])

  asistencias Asistencia[]

  @@unique([docenteId, grupoId, areaId])
}
